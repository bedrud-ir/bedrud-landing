---
import { FeaturesSection } from "~/components/landing/features-section";
import Landing from "~/layouts/Landing.astro";
import { isValidLocale, type Locale, supportedLocales, t } from "../../i18n/utils";

export function getStaticPaths() {
  return supportedLocales.map((lang) => ({ params: { lang } }));
}

const { lang: rawLang } = Astro.params;
const lang: Locale = isValidLocale(rawLang) ? rawLang : "en";
---

<Landing
  lang={lang}
  title={t(lang, "featuresPage.meta.title")}
  description={t(lang, "featuresPage.meta.description")}
>
  <section class="py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h1
        data-animate="fade-up"
        class="text-4xl font-bold tracking-tight sm:text-5xl"
      >
        {t(lang, "featuresPage.title")}
      </h1>
      <p
        data-animate="fade-up"
        class="mt-4 text-lg text-muted-foreground"
        style="transition-delay: 80ms"
      >
        {t(lang, "featuresPage.subtitle")}
      </p>
    </div>
  </section>
  <FeaturesSection client:visible lang={lang} />
  <section class="py-20">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <h2
        data-animate="fade-up"
        class="text-3xl font-bold"
      >
        {t(lang, "featuresPage.ready")}
      </h2>
      <div class="mt-8">
        <a
          href={`/${lang}/docs/getting-started/quickstart`}
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          {t(lang, "featuresPage.readyCta")}
        </a>
      </div>
    </div>
  </section>
</Landing>

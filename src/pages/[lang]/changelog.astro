---
import Landing from "../../layouts/Landing.astro";
import ChangelogSection from "../../components/landing/changelog-section";
import {
  type Locale,
  isValidLocale,
  supportedLocales,
  t,
} from "../../i18n/utils";

export function getStaticPaths() {
  return supportedLocales.map((lang) => ({ params: { lang } }));
}

const { lang: rawLang } = Astro.params;
const lang: Locale = isValidLocale(rawLang) ? rawLang : "en";
---

<Landing
  lang={lang}
  title={t(lang, "changelogPage.meta.title")}
  description={t(lang, "changelogPage.meta.description")}
>
  <ChangelogSection client:visible lang={lang} />
</Landing>

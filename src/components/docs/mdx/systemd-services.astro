---
import { isValidLocale, type Locale, t } from "~/i18n/utils";

const pathname = Astro.url.pathname;
const langMatch = pathname.match(/^\/([a-z]{2})\//);
const lang: Locale = langMatch && isValidLocale(langMatch[1]) ? (langMatch[1] as Locale) : "en";
---

<div class="my-6">
	<h2 class="text-2xl font-semibold tracking-tight scroll-m-20">
		{t(lang, "docs.mdx.systemdServices.title")}
	</h2>
	<p class="mt-4 leading-7 text-muted-foreground">
		{t(lang, "docs.mdx.systemdServices.description")}
	</p>
	<table class="my-6 w-full border-collapse">
		<thead class="border-b border-border">
			<tr>
				<th class="px-4 py-2 text-left text-sm font-semibold">
					{t(lang, "docs.mdx.systemdServices.headerService")}
				</th>
				<th class="px-4 py-2 text-left text-sm font-semibold">
					{t(lang, "docs.mdx.systemdServices.headerCommand")}
				</th>
				<th class="px-4 py-2 text-left text-sm font-semibold">
					{t(lang, "docs.mdx.systemdServices.headerPurpose")}
				</th>
			</tr>
		</thead>
		<tbody>
			<tr class="border-t border-border">
				<td class="px-5 py-3 text-sm">
					<code class="font-mono">bedrud.service</code>
				</td>
				<td class="px-5 py-3 text-sm">
					<code class="font-mono">
						bedrud --run --config /etc/bedrud/config.yaml
					</code>
				</td>
				<td class="px-5 py-3 text-sm">{t(lang, "docs.mdx.systemdServices.purposeApi")}</td>
			</tr>
			<tr class="border-t border-border">
				<td class="px-5 py-3 text-sm">
					<code class="font-mono">livekit.service</code>
				</td>
				<td class="px-5 py-3 text-sm">
					<code class="font-mono">
						bedrud --livekit --config /etc/bedrud/livekit.yaml
					</code>
				</td>
				<td class="px-5 py-3 text-sm">{t(lang, "docs.mdx.systemdServices.purposeMedia")}</td>
			</tr>
		</tbody>
	</table>
</div>

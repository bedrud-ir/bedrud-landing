---
import { generateId } from "./tabs-utils";

interface Props {
	defaultValue?: string;
}

const { defaultValue } = Astro.props;
const groupId = generateId();
---

<div class="mdx-tabs my-6 flex flex-col gap-2" data-tabs={groupId} data-default={defaultValue}>
	<slot />
	<script>
		(() => {
			const root = document.currentScript?.parentElement;
			if (!root) return;

			const defaultVal = root.dataset.default;
			const triggers = root.querySelectorAll<HTMLElement>("[data-tab-trigger]");
			const contents = root.querySelectorAll<HTMLElement>("[data-tab-content]");

			function activate(value: string) {
				triggers.forEach((t) => {
					const isActive = t.dataset.tabTrigger === value;
					t.classList.toggle("tab-active", isActive);
					t.setAttribute("aria-selected", String(isActive));
				});
				contents.forEach((c) => {
					const isActive = c.dataset.tabContent === value;
					c.hidden = !isActive;
				});
			}

			triggers.forEach((t) => {
				t.addEventListener("click", () => {
					activate(t.dataset.tabTrigger!);
				});
			});

			activate(defaultVal || triggers[0]?.dataset.tabTrigger || "");
		})();
	</script>
</div>

<style>
	[data-tab-trigger] {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		white-space: nowrap;
		border-radius: 0.375rem;
		padding: 0.25rem 0.75rem;
		font-size: 0.875rem;
		font-weight: 500;
		cursor: pointer;
		border: none;
		background: transparent;
		color: var(--color-muted-foreground);
		transition: all 0.15s;
	}

	[data-tab-trigger].tab-active {
		background: var(--color-background);
		color: var(--color-foreground);
		box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
	}

	[data-tab-content] {
		min-height: 0;
	}

	[data-tab-content][hidden] {
		display: none;
	}
</style>

---
import { Icon } from "astro-icon/components";
import type { Locale } from "../../i18n/utils";

interface Props {
  lang: Locale;
  title: string;
  description: string;
  date: string;
  author: string;
  tags: string[];
}

const { lang, title, description, date, author, tags } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString(lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<header class="mb-8 border-b border-border pb-6">
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
  <p class="mt-3 text-lg text-muted-foreground">{description}</p>
  <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
    <span class="inline-flex items-center gap-1.5">
      <Icon name="lucide:calendar" class="size-3.5" />
      {formattedDate}
    </span>
    <span class="inline-flex items-center gap-1.5">
      <Icon name="lucide:user" class="size-3.5" />
      {author}
    </span>
    {tags.length > 0 && (
      <span class="inline-flex items-center gap-1.5">
        <Icon name="lucide:tag" class="size-3.5" />
        {tags.join(", ")}
      </span>
    )}
  </div>
</header>

---
import { Icon } from "astro-icon/components";
import type { Locale } from "../../i18n/utils";

interface Props {
  lang: Locale;
  slug: string;
  title: string;
  description: string;
  date: string;
  author: string;
  tags: string[];
}

const { lang, slug, title, description, date, author, tags } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString(lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<article class="group border-b border-border py-8 first:pt-0 last:border-b-0">
  <a href={`/${lang}/blog/${slug}`} class="block transition-colors">
    <h2 class="text-xl font-semibold tracking-tight transition-colors group-hover:text-primary">
      {title}
    </h2>
    <p class="mt-2 text-muted-foreground leading-relaxed">
      {description}
    </p>
    <div class="mt-3 flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
      <span class="inline-flex items-center gap-1.5">
        <Icon name="lucide:calendar" class="size-3.5" />
        {formattedDate}
      </span>
      <span class="inline-flex items-center gap-1.5">
        <Icon name="lucide:user" class="size-3.5" />
        {author}
      </span>
      {tags.length > 0 && (
        <span class="inline-flex items-center gap-1.5">
          <Icon name="lucide:tag" class="size-3.5" />
          {tags.join(", ")}
        </span>
      )}
    </div>
  </a>
</article>

---
import Base from "./Base.astro";
import { Footer } from "~/components/landing/footer";
import { isValidLocale, type Locale } from "../i18n/utils";
import { Navbar } from "~/components/landing/navbar";

interface Props {
  lang: string;
  narrow?: boolean;
  title?: string;
  description?: string;
  jsonLd?: Record<string, unknown>[];
}

const {
  lang: rawLang = "en",
  narrow = false,
  title,
  description,
  jsonLd,
} = Astro.props;
const lang: Locale = isValidLocale(rawLang) ? rawLang : "en";
---

<Base lang={lang} title={title} description={description} jsonLd={jsonLd}>
  <Navbar client:load lang={lang} />
  <div class="h-16" />
  <main id="main-content" class={narrow ? "mx-auto max-w-3xl px-6 py-16" : undefined}>
    <slot />
  </main>
  <Footer client:load lang={lang} />
</Base>
